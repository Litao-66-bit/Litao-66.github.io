                <button onclick="closeWorryModal()" class="text-gray-500 hover:text-gray-700">
                    <i class="fa fa-times text-xl"></i>
                </button>
            </div>
            <div class="p-4">
                <textarea id="worryContent" class="w-full h-32 p-3 border rounded-lg text-sm paper-bg" placeholder="在这里写下你的烦恼..."></textarea>
                <div class="flex justify-between mt-3">
                    <label class="flex items-center text-sm">
                        <input type="checkbox" id="anonymousCheckbox" class="mr-2">
                        匿名发布
                    </label>
                    <button class="bg-primary text-white px-4 py-2 rounded-full text-sm" onclick="submitWorry()">发布</button>
                </div>
            </div>
        </div>
    </div>

    <!-- 底部导航栏 -->
    <footer class="fixed bottom-0 left-0 right-0 bg-white nav-shadow z-40">
        <div class="container mx-auto px-4">
            <div class="flex justify-around py-3">
                <a href="index.html" class="flex flex-col items-center text-gray-600">
                    <i class="fa fa-home text-xl"></i>
                    <span class="text-xs mt-1">首页</span>
