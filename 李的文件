                'surprised': '哇，发生了什么有趣的事情吗？可以分享给我哦~'
            };
            addMessage('bot', moodResponses[mood]);
        }

        // 音乐匹配
        function matchMusic() {
            const currentMood = localStorage.getItem('currentMood') || 'happy';
            const musicRecommendations = {
                'happy': '推荐你听《Happy》，让快乐加倍！',
                'sad': '推荐你听《Someone Like You》，释放你的情绪。',
