    <div class="flex justify-center mt-8 mb-20">
        <button class="w-24 h-24 bg-primary rounded-full flex items-center justify-center shadow-lg" id="startLightBtn">
            <span class="text-white font-medium">一键助眠灯光</span>
        </button>
    </div>

