            };
            alert(musicRecommendations[currentMood]);
            // 这里可以跳转到音乐播放页面
            window.location.href='music_control.html';
        }

        // 发送消息
        function sendMessage() {
            const input = document.getElementById('messageInput');
            const message = input.value.trim();
            if (!message) return;

            // 添加用户消息
            addMessage('user', message);
            input.value = '';

            // 模拟AI回复
            setTimeout(() => {
                const botResponses = [
                    '我理解你的感受。',
                    '这听起来很有趣！',
                    '谢谢你的分享。',
                    '你说得对。',
                    '我在这里支持你。'
                ];
                const randomResponse = botResponses[Math.floor(Math.random() * botResponses.length)];
                addMessage('bot', randomResponse);
            }, 1000);
        }

        // 添加消息到聊天框
        function addMessage(sender, text) {
            const chatContainer = document.getElementById('chatContainer');
            const messageDiv = document.createElement('div');
            messageDiv.className = `flex mb-4 ${sender === 'user' ? 'justify-end' : 'justify-start'}`;
            messageDiv.innerHTML = `
                <div class="${sender === 'user' ? 'bg-primary text-white' : 'bg-light'} rounded-lg py-2 px-4 max-w-xs">
                    <p class="text-sm">${text}</p>
                </div>
            `;
            chatContainer.appendChild(messageDiv);
            chatContainer.scrollTop = chatContainer.scrollHeight;
        }

        // 允许按Enter发送消息
        document.getElementById('messageInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                sendMessage();
            }
        });
    </script>
