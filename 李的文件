        </div>
    </footer>

    <script>
        // 返回按钮功能
        document.getElementById('backButton').addEventListener('click', function() {
            window.history.back();
        });

        // 模拟数据
        let worries = [
            {
                id: 1,
                content: '最近工作压力好大，感觉快要被压垮了...',
                author: '匿名用户',
                date: '2小时前',
                likes: 15,
                comments: 5
            },
            {
                id: 2,
                content: '和家人吵架了，心情很糟糕，该怎么和解？',
                author: '小A',
                date: '5小时前',
                likes: 23,
                comments: 8
            }
        ];

        // 渲染烦恼列表
        function renderWorryList() {
            const worryList = document.getElementById('worryList');
            worryList.innerHTML = '';
            worries.forEach(worry => {
                const worryElement = document.createElement('div');
                worryElement.className = 'bg-white rounded-lg p-4 card-shadow mb-4';
                worryElement.innerHTML = `
                    <div class="flex justify-between items-center mb-2">
                        <span class="text-sm font-medium">${worry.author}</span>
                        <span class="text-xs text-gray-500">${worry.date}</span>
                    </div>
                    <p class="text-sm text-gray-600 mb-3">${worry.content}</p>
                    <div class="flex justify-between items-center text-sm text-gray-500">
                        <button class="flex items-center" onclick="likeWorry(${worry.id})"><i class="fa fa-heart-o mr-1"></i> <span>${worry.likes}</span></button>
                        <button class="flex items-center" onclick="showComments(${worry.id})"><i class="fa fa-comment-o mr-1"></i> <span>${worry.comments}</span></button>
                        <button class="flex items-center"><i class="fa fa-share-alt mr-1"></i> 分享</button>
                    </div>
                `;
                worryList.appendChild(worryElement);
            });
        }

        // 显示发布烦恼弹窗
        function showWorryForm() {
            document.getElementById('worryModal').classList.remove('hidden');
        }

        // 关闭发布烦恼弹窗
        function closeWorryModal() {
            document.getElementById('worryModal').classList.add('hidden');
        }

        // 提交烦恼
        function submitWorry() {
            const content = document.getElementById('worryContent').value.trim();
            if (!content) {
                alert('请输入烦恼内容');
                return;
            }

            const anonymous = document.getElementById('anonymousCheckbox').checked;
            const newWorry = {
                id: Date.now(),
                content: content,
                author: anonymous ? '匿名用户' : '我',
                date: '刚刚',
                likes: 0,
                comments: 0
            };

            worries.unshift(newWorry);
            renderWorryList();
            document.getElementById('worryModal').classList.add('hidden');
            document.getElementById('worryContent').value = '';
            document.getElementById('anonymousCheckbox').checked = false;
        }

        // 点赞
        function likeWorry(id) {
            const worry = worries.find(w => w.id === id);
            if (worry) {
                worry.likes++;
                renderWorryList();
            }
        }

        // 显示评论
        function showComments(id) {
            alert('评论功能开发中...');
        }

        // 查看历史信件
        function showHistoryLetters() {
            alert('正在加载历史信件...');
            // 这里可以跳转到历史信件页面
        }

        // 显示咨询表单
        function showConsultationForm() {
            window.location.href = 'consultation.html';
        }

        // 逛解忧博物馆
        function showMuseum() {
            window.location.href = 'museum.html';
        }

        // 页面加载时渲染列表
        window.onload = renderWorryList;
    </script>
