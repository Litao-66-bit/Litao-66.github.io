<body class="bg-gray-50 font-sans" style="padding-bottom: 80px;">
    <!-- 顶部导航栏 -->
    <header class="gradient-header text-white shadow-md sticky top-0 z-50">
        <div class="flex items-center px-4 py-3">
            <button onclick="window.location.href='health.html'" class="mr-4 w-8 h-8 flex items-center justify-center rounded-full bg-white/20 hover:bg-white/30 transition-colors">
                <i class="fa fa-arrow-left"></i>
            </button>
            <h1 class="text-lg font-bold tracking-wide flex-grow text-center">数据统计</h1>
            <div class="w-8"></div>
        </div>
    </header>

    <!-- 时间筛选标签 -->
    <div class="px-4 py-4 overflow-x-auto whitespace-nowrap">
        <div class="inline-flex space-x-2 bg-white rounded-full p-1 shadow-sm">
            <button class="tab-item active" data-period="day">日</button>
            <button class="tab-item" data-period="week">周</button>
            <button class="tab-item" data-period="month">月</button>
            <button class="tab-item" data-period="year">年</button>
        </div>
    </div>

    <!-- 主要图表 -->
    <div class="mx-4 mb-4">
        <div class="bg-white rounded-2xl shadow-sm overflow-hidden p-5">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-sm font-bold text-gray-800 flex items-center">
                    <i class="fa fa-line-chart text-primary mr-2"></i>
                    使用趋势
                </h3>
                <span class="text-xs text-gray-400">使用时长（分钟）</span>
            </div>
            <div class="h-52">
                <canvas id="mainChart"></canvas>
            </div>
        </div>
    </div>

    <!-- 概览统计卡片 -->
    <div class="grid grid-cols-4 gap-2 px-4 mb-4">
        <div class="bg-white rounded-xl p-3 text-center shadow-sm">
            <p class="text-xs text-gray-500 mb-1">日均使用</p>
            <p class="text-lg font-bold text-primary">45<span class="text-xs font-normal text-gray-400">min</span></p>
        </div>
        <div class="bg-white rounded-xl p-3 text-center shadow-sm">
            <p class="text-xs text-gray-500 mb-1">睡眠评分</p>
            <p class="text-lg font-bold text-green-500">82<span class="text-xs font-normal text-gray-400">分</span></p>
        </div>
        <div class="bg-white rounded-xl p-3 text-center shadow-sm">
            <p class="text-xs text-gray-500 mb-1">情绪指数</p>
            <p class="text-lg font-bold text-blue-500">76<span class="text-xs font-normal text-gray-400">分</span></p>
        </div>
        <div class="bg-white rounded-xl p-3 text-center shadow-sm">
            <p class="text-xs text-gray-500 mb-1">改善率</p>
            <p class="text-lg font-bold text-amber-500">+12<span class="text-xs font-normal text-gray-400">%</span></p>
        </div>
    </div>

    <!-- 数据卡片 -->
    <div class="grid grid-cols-2 gap-4 px-4">
        <!-- 睡眠卡片 -->
        <div class="data-card" onclick="window.location.href='sleep_detail.html'">
            <div class="flex justify-between items-center mb-3">
                <div class="flex items-center">
                    <div class="w-8 h-8 rounded-full bg-purple-100 flex items-center justify-center mr-2">
                        <i class="fa fa-moon-o text-primary"></i>
                    </div>
                    <h3 class="text-sm font-medium text-gray-800">睡眠</h3>
                </div>
                <i class="fa fa-angle-right text-gray-400 text-xs"></i>
            </div>
