                <span>首页</span>
            </a>
            <a href="health.html" class="nav-item">
                <i class="fa fa-heartbeat text-xl mb-1"></i>
                <span>健康中心</span>
            </a>
            <a href="profile.html" class="nav-item">
                <i class="fa fa-user text-xl mb-1"></i>
                <span>我的</span>
            </a>
        </div>
    </div>

    <script>
        // 亮度滑块
        const brightnessSlider = document.getElementById('brightnessSlider');
        const brightnessValue = document.getElementById('brightnessValue');
        
        brightnessSlider.addEventListener('input', function() {
            brightnessValue.textContent = this.value + '%';
        });

        // 色温滑块
        const temperatureSlider = document.getElementById('temperatureSlider');
        const temperatureValue = document.getElementById('temperatureValue');
        
        temperatureSlider.addEventListener('input', function() {
            const value = parseInt(this.value);
            if (value < 33) {
                temperatureValue.textContent = '冷色';
            } else if (value < 66) {
                temperatureValue.textContent = '中性';
            } else {
                temperatureValue.textContent = '暖色';
            }
        });

        // 时长滑块
        const durationSlider = document.getElementById('durationSlider');
        const durationValue = document.getElementById('durationValue');
        
        durationSlider.addEventListener('input', function() {
            durationValue.textContent = this.value + '分钟';
        });

        // 颜色选择
        document.querySelectorAll('.color-option').forEach(option => {
            option.addEventListener('click', function() {
                document.querySelectorAll('.color-option').forEach(o => o.classList.remove('active'));
                this.classList.add('active');
                const color = this.getAttribute('data-color');
                document.querySelector('.text-sm.text-gray-600').textContent = `色温：${color}光`;
            });
        });

        // 一键助眠灯光按钮
        const startLightBtn = document.getElementById('startLightBtn');
        let isLightOn = false;
        
        startLightBtn.addEventListener('click', function() {
            isLightOn = !isLightOn;
            if (isLightOn) {
                this.style.background = '#ff4081';
                this.querySelector('span').textContent = '关闭灯光';
                alert('开启助眠灯光');
            } else {
                this.style.background = '#9c27b0';
                this.querySelector('span').textContent = '一键助眠灯光';
                alert('关闭灯光');
            }
        });
    </script>
