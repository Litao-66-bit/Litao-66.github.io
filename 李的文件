    <script>
        // 播放/暂停按钮
        const playBtn = document.getElementById('playBtn');
        let isPlaying = false;
        
        playBtn.addEventListener('click', function() {
            isPlaying = !isPlaying;
            const icon = this.querySelector('i');
            if (isPlaying) {
                icon.classList.remove('fa-play');
                icon.classList.add('fa-pause');
                alert('开始播放音乐');
            } else {
                icon.classList.remove('fa-pause');
                icon.classList.add('fa-play');
                alert('暂停播放');
            }
        });

        // 音乐列表点击事件
        document.querySelectorAll('.music-item').forEach(item => {
            item.addEventListener('click', function() {
                // 移除其他项的active状态
                document.querySelectorAll('.music-item').forEach(i => {
                    i.classList.remove('active');
                    i.querySelector('i').classList.remove('fa-volume-up', 'text-primary');
                    i.querySelector('i').classList.add('fa-play', 'text-gray-400');
                });
                
                // 添加当前项的active状态
                this.classList.add('active');
                this.querySelector('i').classList.remove('fa-play', 'text-gray-400');
                this.querySelector('i').classList.add('fa-volume-up', 'text-primary');
                
                // 更新播放器标题
                const songName = this.getAttribute('data-song');
                document.querySelector('.text-2xl.font-bold').textContent = songName;
                
                // 自动播放
                if (!isPlaying) {
                    playBtn.click();
                }
            });
        });
    </script>
